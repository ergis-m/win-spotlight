{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Win Spotlight",
  "version": "0.2.4",
  "identifier": "com.win-spotlight.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFERjNGNDQ5OEY4RkQwOEUKUldTTzBJK1BTZlR6clE0V3hGdW9aclVaRWhPdzFLZkhEVDlkZ3hoQlc1dEY3UUFjMWxkZUhoNmkK",
      "endpoints": [
        "https://github.com/ergis-m/win-spotlight/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Win Spotlight",
        "width": 640,
        "height": 420,
        "center": true,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "settings",
        "url": "settings.html",
        "title": "Settings",
        "width": 800,
        "height": 560,
        "minWidth": 500,
        "minHeight": 400,
        "center": true,
        "visible": false
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "Win Spotlight"
    }
  }
}