{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "sortPackageJson": false,
  "ignorePatterns": [
    "dist/",
    "src-tauri/target/",
    "node_modules/",
    "pnpm-lock.yaml"
  ]
}
